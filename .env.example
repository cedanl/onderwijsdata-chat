# Model in litellm-formaat: provider/model-naam
# Zie https://docs.litellm.ai/docs/providers voor alle opties
MODEL=anthropic/claude-sonnet-4-6

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
# MODEL=openai/gpt-4o
# OPENAI_API_KEY=

# --- Azure OpenAI (GPT-4o etc.) ---
# MODEL=azure/gpt-4o
# AZURE_API_KEY=
# AZURE_API_BASE=https://<resource>.openai.azure.com
# AZURE_API_VERSION=2024-02-01

# --- Azure AI Foundry + Claude (Sonnet, Haiku, Opus) ---
# MODEL=azure_ai/claude-sonnet-4-5
# AZURE_AI_API_KEY=
# AZURE_AI_API_BASE=https://<resource>.services.ai.azure.com/anthropic

# --- Azure AI Foundry (Llama, Mistral, Phi etc.) ---
# MODEL=azure_ai/Llama-3.1-70B-Instruct
# AZURE_AI_API_KEY=
# AZURE_AI_API_BASE=https://<endpoint>.services.ai.azure.com/models

# --- Google Gemini ---
# MODEL=gemini/gemini-1.5-pro
# GEMINI_API_KEY=

# --- Ollama (lokaal, geen cloud API key nodig) ---
# Gebruik ollama_chat/ (niet ollama/) — alleen ollama_chat ondersteunt tool calling
# MODEL=ollama_chat/gpt-oss:20b
# OPENAI_API_BASE=http://localhost:11434/v1
# In Docker: gebruik http://host.docker.internal:11434/v1

# --- SURF Willma AI-Hub ---
# Run willma_poc.py om beschikbare model-namen op te halen.
# MODEL=openai/<model-naam>
# WILLMA_API_KEY=
# WILLMA_BASE_URL=https://willma.surf.nl/api/v0

# --- Model-picker in de UI ---
# Kommagescheiden lijst van LiteLLM model-IDs die zichtbaar zijn in de model-picker.
# Niet ingesteld → geen picker, de app gebruikt altijd MODEL hierboven.
# Modellen van meerdere providers mogen gecombineerd worden — elke provider heeft zijn eigen API key nodig.
# AVAILABLE_MODELS=azure_ai/claude-sonnet-4-6,azure_ai/claude-haiku-4-5,azure_ai/gpt-4o

# --- Chatgeschiedenis (optioneel) ---
# Genereer een secret met: chainlit create-secret
# CHAINLIT_AUTH_SECRET=

# Gebruikers voor wachtwoord-authenticatie (formaat: user:pass,user2:pass2)
# CHAT_USERS=admin:geheim

# Of: header-authenticatie via reverse proxy
# CHAT_HEADER_SECRET=<gedeeld-geheim>

# Database voor chatgeschiedenis (standaard: lokale SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./chat_history.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/onderwijschat
